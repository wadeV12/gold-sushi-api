# Production Environment Variables Template
# Copy this file and fill in your actual values

# Application
FORTEND_URL=https://yourfrontend.com
NODE_ENV=production
PORT=4200

# JWT Configuration
JWT_ACCESS=your-super-secret-jwt-access-key-change-this
JWT_REFRESH=your-super-secret-jwt-refresh-key-change-this
JWT_ACCESS_MAX_AGE=3600
JWT_REFRESH_MAX_AGE=604800

# Database Configuration (Digital Ocean Managed Database recommended)
DB_HOST=your-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_PASSWORD=your-secure-database-password
DB_USERNAME=doadmin
DB_DATABASE=goldsushi

# Docker Registry (for GitHub Container Registry)
DOCKER_REGISTRY=ghcr.io/yourusername
IMAGE_TAG=latest

# Google Cloud Configuration (if using)
GC_KEYPATH=/path/to/service-account-key.json
GC_PROJECT=your-google-cloud-project-id
GC_BUCKET=your-storage-bucket-name

# Payment System (LiqPay)
LIQPAY_PUBLIC=your-liqpay-public-key
LIQPAY_PRIVATE=your-liqpay-private-key

# Digital Ocean Deployment (for CI/CD)
DROPLET_IP=your.droplet.ip.address
SSH_USER=root

